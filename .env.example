# Tocha Padaria - Credenciais Exemplo
# Preencha com as suas chaves reais no arquivo .env

# STRIPE
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# SUPABASE
SUPABASE_URL=https://...
SUPABASE_SERVICE_KEY=sb_secret_...

# SMTP (E-mail Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tocha.padariapagamentos@gmail.com
# Senha de App do Google (16 letras sem espaços)
SMTP_PASS=xxxxxxxxxxxxxxxx

# SERVIDOR
PORT=3333
JWT_SECRET=troque-por-uma-string-secreta-longa

# WHATSAPP / NOTIFICAÇÕES
OWNER_WHATSAPP=5521999999999
# Define se mensagens automáticas usam IA (true/false)
USE_AI_NOTIFICATIONS=false

# CARRINHO ABANDONADO
# Minutos de inatividade antes de considerar carrinho abandonado
ABANDON_DELAY_MINUTES=30
# URL base do servidor (usada nos links de recuperação de carrinho)
BASE_URL=http://localhost:3333

# ADMIN (fallback de autenticação local, se Supabase estiver indisponível)
ADMIN_USER=admin
ADMIN_PASS=troque-por-senha-forte

# ANTIGRAVITY AI (opcional — geração de mensagens com IA)
ANTIGRAVITY_API_URL=https://api.antigravity.ai/v1
ANTIGRAVITY_MODEL_PRIMARY=claude-sonnet-4-6
ANTIGRAVITY_MODEL_FALLBACK=claude-haiku-4-5-20251001
ANTIGRAVITY_API_KEY=ag-...

# DIAGNÓSTICO WHATSAPP (endpoint /comparative-audit)
# Números separados por vírgula para testar registro no WhatsApp
AUDIT_PHONES=5521999999999

# PUPPETEER (apenas se usar browser headless)
# CHROME_PATH=/usr/bin/google-chrome
